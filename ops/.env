# ⚠️ docker compose file will read this .env file and inject the variables into the containers.
# Do not change the variable names as they are used in the docker-compose.yml file.
# or run with `docker compose --env-file  path/**/.env up` to specify the env file explicitly.
ENV=local

# PostgreSQL
POSTGRES_USER=admin
POSTGRES_PASSWORD=admin
POSTGRES_DB=kickstart_db
POSTGRES_URL=jdbc:postgresql://localhost:5432/kickstart_db

# keycloak
KC_ADMIN=admin
KC_ADMIN_PASSWORD=admin
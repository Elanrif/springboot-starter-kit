# ⚠️ Spring dotEnv don't do interpolation in .env files, so we need to repeat the values for the URLs
ENV=local
SERVER_PORT=8081
SERVER_NAME=kickstart-springboot-template
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173,http://localhost:8080

# PostgreSQL
POSTGRES_USER=admin
POSTGRES_PASSWORD=admin
POSTGRES_DB=kickstart_db
POSTGRES_URL=jdbc:postgresql://localhost:5432/kickstart_db

# Keycloak

# Admin console
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=admin

# Application
KEYCLOAK_REALM=kickstart-springboot-realm
KEYCLOAK_CLIENT_ID=kickstart-springboot-client
KEYCLOAK_CLIENT_SECRET=change-me
KEYCLOAK_ISSUER_URI=http://keycloak:8080/realms/kickstart-springboot-realm
KEYCLOAK_JWK_URL=http://keycloak:8080/realms/kickstart-springboot-realm/protocol/openid-connect/certs
KEYCLOAK_AUTH_SERVER_URL=http://keycloak:8080
